# Caminho do arquivo SQLite (deve ficar fora do container em produção)
DB_PATH=./data/myprovenance.sqlite

# Porta HTTP do servidor (adapter-node)
PORT=3000

# URL publica externa desta instancia (ex.: atras de proxy/porta mapeada no Docker). Usada para
# montar o link publico de compartilhamento de Registros. Sem barra final.
URL_BASE=http://localhost:3000

# Senha da area administrativa (/admin — gestao global de usuarios, registros, agentes e
# compartilhamentos). Sem esta variavel, o link "Admin" fica oculto e a area fica inacessivel.
ADM_PWD=
